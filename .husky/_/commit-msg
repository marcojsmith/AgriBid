#!/usr/bin/env sh
. "$(dirname "$0")/h"

# Check that strictTypeChecked and stylisticTypeChecked are NOT uncommented in eslint.config.js
# This ensures the pre-commit hook passes while allowing developers to enable strict mode during development
STAGED_ESLINT=$(git diff --cached --name-only | grep -E "eslint\.config\.js$" | head -1)
CURRENT_ESLINT="eslint.config.js"

check_strict_disabled() {
  if [ -t 0 ]; then
    # Reading from file argument
    if grep -q "^[[:space:]]*tseslint\.configs\.strictTypeChecked," "$1" 2>/dev/null; then
      echo "ERROR: eslint.config.js has strictTypeChecked uncommented. Revert to 'recommended' before committing."
      echo "       Run 'bun run lint:strict' locally to voluntarily check strict mode compliance."
      exit 1
    fi
    if grep -q "^[[:space:]]*tseslint\.configs\.stylisticTypeChecked," "$1" 2>/dev/null; then
      echo "ERROR: eslint.config.js has stylisticTypeChecked uncommented. Revert to 'recommended' before committing."
      echo "       Run 'bun run lint:strict' locally to voluntarily check strict mode compliance."
      exit 1
    fi
  else
    # Reading from stdin
    if grep -q "^[[:space:]]*tseslint\.configs\.strictTypeChecked,"; then
      echo "ERROR: eslint.config.js has strictTypeChecked uncommented. Revert to 'recommended' before committing."
      echo "       Run 'bun run lint:strict' locally to voluntarily check strict mode compliance."
      exit 1
    fi
    if grep -q "^[[:space:]]*tseslint\.configs\.stylisticTypeChecked,"; then
      echo "ERROR: eslint.config.js has stylisticTypeChecked uncommented. Revert to 'recommended' before committing."
      echo "       Run 'bun run lint:strict' locally to voluntarily check strict mode compliance."
      exit 1
    fi
  fi
}

if [ -n "$STAGED_ESLINT" ]; then
  git show ":$STAGED_ESLINT" | check_strict_disabled
elif [ -f "$CURRENT_ESLINT" ]; then
  check_strict_disabled "$CURRENT_ESLINT"
fi