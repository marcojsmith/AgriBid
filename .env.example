# App / PWA manifest (optional — falls back to generic defaults)
VITE_APP_NAME=AgriBid
VITE_APP_SHORT_NAME=AgriBid
VITE_APP_DESCRIPTION=Real-time auction platform for agricultural products
VITE_APP_THEME_COLOR=#16a34a

# Convex
VITE_CONVEX_URL=your_convex_url_here
VITE_CONVEX_SITE_URL=your_convex_site_url_here

# Better Auth
BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=http://localhost:5173

# CORS - Required for local development
# Comma-separated list of allowed origins for cross-origin requests
# Omitting this will block all CORS requests
ALLOWED_ORIGINS=http://localhost:5173

# Cryptographically secure 32-byte key for PII encryption (e.g., openssl rand -hex 32)
PII_ENCRYPTION_KEY="GENERATE_SECURE_32_BYTE_HEX_KEY_HERE"