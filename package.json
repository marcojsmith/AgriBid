{
  "name": "app",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "vite",
    "build": "tsgo -b tsconfig.build.json && vite build",
    "type-check": "tsgo -b tsconfig.build.json --noEmit",
    "lint": "eslint . && echo 'No lint issues found.'",
    "lint:strict": "bun run lint && bunx eslint . --rule '@typescript-eslint/strict-type-checked: error' 2>/dev/null || bun run lint",
    "format": "prettier --write .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "mkdir -p ./test-coverage && vitest run --coverage 2>&1 | tee ./test-coverage/latest-coverage-output.txt && echo './test-coverage/latest-coverage-output.txt has been updated with the latest test coverage report.'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bunx prettier --write",
      "bunx eslint --fix",
      "bash -c 'tsgo -p tsconfig.json --noEmit && tsgo -p convex/tsconfig.json --noEmit'"
    ],
    "*.js": [
      "bunx eslint --fix --max-warnings=0"
    ],
    "*.{css,json,md}": [
      "bunx prettier --write"
    ]
  },
  "dependencies": {
    "@convex-dev/aggregate": "^0.2.1",
    "@convex-dev/better-auth": "^0.10.10",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "better-auth": "^1.4.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "1.33.1",
    "lucide-react": "^0.563.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260323.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-istanbul": "4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "4.0.18",
    "autoprefixer": "^10.4.24",
    "convex-test": "^0.0.41",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsdoc": "^50.6.3",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
